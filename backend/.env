# Dashboard IoT — interval refresh WebSocket (detik). Opsional, boleh
# dikosongkan/dihapus baris ini kalau mau pakai default (2 & 5 detik).
IOT_WS_REFRESH_STATUS_SEC=2
IOT_WS_REFRESH_SALES_SEC=5